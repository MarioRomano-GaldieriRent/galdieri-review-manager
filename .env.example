# === Database (MongoDB) ===
# Il mongod è CONDIVISO con un'altra applicazione (portale_assenze) e gira già
# in locale su questa porta. L'app usa un database dedicato, galdieri_recensioni:
# NON cambiare questo nome, e in particolare non puntarlo su portale_assenze.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=galdieri_recensioni

# === Microsoft Graph (app registration Azure, permessi APPLICATIVI Mail.Read) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
GRAPH_API_URL=https://graph.microsoft.com/v1.0

# Casella da mostrare in "Posta in arrivo"
MAIL_WATCH_ADDRESS=nome.cognome@galdierirent.it

# === Traduzione in italiano (Azure AI Translator) ===
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# === Freshdesk (ticketing) — configurabile anche dal pannello Impostazioni ===
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# === Google Business Profile (recensioni) — non ancora attiva ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_ID=
