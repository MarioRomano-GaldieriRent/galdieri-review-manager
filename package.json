{
  "name": "galdieri-review-manager",
  "version": "0.3.0",
  "private": true,
  "description": "Posta in arrivo Galdieri rent — legge una casella Microsoft 365 via Graph",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:graph": "tsx scripts/test-graph.ts",
    "test:automazioni": "tsx --tsconfig tsconfig.json scripts/test-automazioni.ts",
    "analisi": "tsx --tsconfig tsconfig.json scripts/analisi-recensioni.ts",
    "test:lingua": "tsx --tsconfig tsconfig.json scripts/test-lingua.ts",
    "analisi:trustpilot": "tsx --tsconfig tsconfig.json scripts/analisi-trustpilot.ts",
    "verifica:db": "tsx --tsconfig tsconfig.json scripts/verifica-db.ts"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
